[Unit]
Description=TH3's distributed currency daemon
After=network.target

[Service]
User=raven
Group=raven

Type=forking
PIDFile=/var/lib/th3d/th3d.pid
ExecStart=/usr/bin/th3d -daemon -pid=/var/lib/th3d/th3d.pid \
-conf=/etc/th3/th3.conf -datadir=/var/lib/th3d -disablewallet

Restart=always
PrivateTmp=true
TimeoutStopSec=60s
TimeoutStartSec=2s
StartLimitInterval=120s
StartLimitBurst=5

[Install]
WantedBy=multi-user.target
